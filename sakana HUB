-- [[ 3. 魚エフェクト ]] --
local emojis = {}
local eRnd = Random.new()
for i = 1, 10 do
    local label = Instance.new("TextLabel", Main)
    label.BackgroundTransparency = 1
    label.Text = "🐟"
    label.TextSize = eRnd:NextInteger(15, 25)
    label.Position = UDim2.new(eRnd:NextNumber(-0.1, 1.1), 0, eRnd:NextNumber(-0.1, 1.1), 0)
    table.insert(emojis, {
        label = label,
        speed = eRnd:NextNumber(1, 2.5),
        amp = eRnd:NextNumber(10, 25),
        angle = eRnd:NextNumber(0, math.pi * 2)
    })
end

RunService.RenderStepped:Connect(function(dt)
    if not Main.Visible then return end
    for _, data in ipairs(emojis) do
        data.angle = data.angle + data.speed * dt
        data.label.Rotation = math.sin(data.angle) * 20
        local offsetX = math.sin(data.angle) * data.amp
        local offsetY = math.cos(data.angle) * (data.amp * 0.5)
        data.label.Position = UDim2.new(data.label.Position.X.Scale, offsetX, data.label.Position.Y.Scale, offsetY)
    end
end)

-- [[ 4. ★ 重要：機能部 (Main.Visibleに関係なく動作) ★ ]] --
local isActive = false
task.spawn(function()
    while true do
        -- UIが消えていても、isActiveがONならハックは実行され続ける
        if isActive then
            pcall(function()
                for _, v in pairs(workspace:GetDescendants()) do
                    if v:IsA("ProximityPrompt") then
                        v.HoldDuration = 0
                        v.RequiresLineOfSight = false
                    end
                end
            end)
        end
        task.wait(0.5)
    end
end)

